rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users: read/write own document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Listings: anyone can read; create requires auth; update/delete only if createdBy matches
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.createdBy == request.auth.uid;
    }

    // Reviews (subcollection under listings): anyone can read; create requires auth
    match /listings/{listingId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
  }
}
